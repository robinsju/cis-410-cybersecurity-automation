# terraform/week8/terraform.tfvars.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your actual values.
# terraform.tfvars is in .gitignore — do NOT commit it to GitHub.
#
#   cp terraform.tfvars.example terraform.tfvars
# ─────────────────────────────────────────────────────────────────────────────

# Your GCP Project ID
# Find it: gcloud config get-value project
project_id = "cis410-yourname-xxxx"

# GCP region — must match the region used in Weeks 6 and 7
region = "us-central1"

# Full image path from Artifact Registry including commit SHA tag.
# Get this value after running: gcloud builds submit --tag ${IMAGE_PATH} .
# Then run: echo $IMAGE_PATH
#
# Replace everything after the = with your actual image path:
container_image = "us-central1-docker.pkg.dev/cis410-yourname-xxxx/cis410-app/flask-app:YOUR_COMMIT_SHA"
